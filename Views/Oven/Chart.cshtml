<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

<div class="row align-items-stretch mb-5 mt-3">

    <div class="col-1 d-flex">
        <div class="card shadow-sm border-0 rounded-4 d-flex justify-content-center align-items-center text-center w-100 h-100">
            <img src="~/Images/Logo.png"
                 alt="Logo empresa"
                 class="img-fluid"
                 style="max-width: 100px; height: auto;">
        </div>
    </div>

    <div class="col-11 d-flex">
        <div class="card shadow-lg rounded-pill p-2 mb-2 bg-info w-100 h-100">

            <div class="d-flex justify-content-between align-items-center px-3">

                <!-- Título -->
                <div class="fw-bold fs-1">Sistema de graficas de Oven</div>

                <!-- Fecha + hora + turno -->
                <div class="text-end">

                    <!-- Ícono + fecha/hora en una sola línea -->
                    <div id="fechaHoraLinea" class="fw-semibold">
                        <i class="bi bi-calendar-date me-1"></i>
                    </div>

                    <!-- Turno debajo -->
                    <div id="turnoActual" class="fw-bold fs-5"><i class="bi bi-clock-history me-1"></i></div>

                </div>

            </div>

        </div>
    </div>

</div>
