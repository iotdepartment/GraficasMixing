    // =========================
    let chart1;

    function loadLatest1() {
        fetch("/Oven/GetLatest?oven=1")
            .then(r => r.json())
            .then(d => {
                document.getElementById("lastPressure").textContent = d.pess + " KPA";
                document.getElementById("lastTemperature").textContent = d.temp + " °C";
            });
    }

    function loadChart1() {
        fetch("/Oven/GetLast10?oven=1")
            .then(r => r.json())
            .then(data => {
                const labels = data.map(x => x.hors.substring(0, 5)); 
                const press = data.map(x => parseFloat(x.pess));
                const temp = data.map(x => parseFloat(x.temp));

                const ctx = document.getElementById("OvenChart1").getContext("2d");

                chart1 = new Chart(ctx, {
                    type: "line",
                    data: {
                        labels: labels,
                        datasets: [
                            { label: "Pressure", data: press, borderColor: "orange", tension: 0.3 },
                            { label: "Temperature", data: temp, borderColor: "red", tension: 0.3 }
                        ]
                    },
                    options: { responsive: true, maintainAspectRatio: false }
                });
            });
    }

    function updateChart1() {
        fetch("/Oven/GetLast10?oven=1")
            .then(r => r.json())
            .then(data => {
                chart1.data.labels = data.map(x => x.hors.substring(0, 5));
                chart1.data.datasets[0].data = data.map(x => parseFloat(x.pess));
                chart1.data.datasets[1].data = data.map(x => parseFloat(x.temp));
                chart1.update();
            });
    }

