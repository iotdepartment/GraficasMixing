@{
    Layout = "~/Views/Oven/Partials/_LayoutNoNav.cshtml";
    ViewData["Title"] = $"Oven {ViewBag.OvenNumber}";
}

<div class="row align-items-stretch mb-4 mt-3">

    <div class="col-1 d-flex">
        <div class="card shadow-sm border-0 rounded-4 d-flex justify-content-center align-items-center text-center w-100 h-100">
            <img src="~/Images/Logo.png"
                 alt="Logo empresa"
                 class="img-fluid"
                 style="max-width: 100px; height: auto;">
        </div>
    </div>

    <div class="col-11 d-flex">
        <div class="card shadow-lg rounded-4 p-2 mb-2 bg-primary w-100 h-100">

            <div class="d-flex justify-content-between align-items-center px-3">
                <!-- Título Dinámico -->
                <div class="fw-bold text-white fs-1">GRAFICA DE TEMPERATURA Y PRESION OVEN @ViewBag.OvenNumber</div>
                <!-- Fecha + hora + turno -->
                <div class="text-end">

                    <!-- Ícono + fecha/hora en una sola línea -->
                    <div id="fechaHoraLinea" class="fw-semibold text-white">
                        <i class="bi bi-calendar-date me-1"></i> <span id="txtFechaHora"></span>
                    </div>

                    <!-- Turno debajo -->
                    <div id="turnoActual" class="fw-bold fs-5 text-white">
                        <i class="bi bi-clock-history me-1"></i> <span id="txtTurno"></span>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>

<div class="row align-items-end mb-4">
    <div class="col-12">
        <div class="card shadow-lg  rounded-4 p-3 position-relative" style="height: 250px;">
            <canvas id="PressureChart" style="width:100%; height:100%;"></canvas>
        </div>
    </div>
</div>

<div class="row align-items-end mb-4">
    <div class="col-12">
        <div class="card shadow-lg  rounded-4 p-3 position-relative" style="height: 250px;">
            <canvas id="TemperatureChart" style="width:100%; height:100%;"></canvas>
        </div>
    </div>
</div>

<div class="row mb-4 mt-2 align-items-stretch">
    <!-- Tarjeta de Presión -->
    <div class="col-3">
        <div class="card shadow-lg bg-warning rounded-4 p-4 text-center d-flex flex-column justify-content-between h-100" style="height: 220px;">
            <div class="fw-bold fs-4 text-black text-uppercase tracking-wider">PRESION ACTUAL</div>
            <div class="d-flex align-items-center justify-content-center flex-grow-1">
                <span id="lastPressure" class="badge bg-warning text-dark rounded-3 py-3 w-100 fw-black" style="font-size: 2.5rem; letter-spacing: -1px;">--</span>
            </div>
        </div>
    </div>

    <!-- Tarjeta de Temperatura -->
    <div class="col-3">
        <div class="card shadow-lg bg-danger rounded-4 p-4 text-center d-flex flex-column justify-content-between h-100" style="height: 220px;">
            <div class="fw-bold fs-4 text-white text-uppercase tracking-wider">TEMPERATURA ACTUAL</div>
            <div class="d-flex align-items-center justify-content-center flex-grow-1">
                <span id="lastTemperature" class="badge bg-danger text-white rounded-3 py-3 w-100 fw-black" style="font-size: 2.5rem; letter-spacing: -1px;">--</span>
            </div>
        </div>
    </div>

    <!-- Nueva Tarjeta de Ciclos -->
    <div class="col-3">
        <div class="card shadow-lg bg-secondary rounded-4 p-4 text-center d-flex flex-column justify-content-between h-100" style="height: 220px;">
            <div class="fw-bold fs-4 text-white text-uppercase tracking-wider">CICLOS DEL TURNO</div>
            <div class="d-flex align-items-center justify-content-center flex-grow-1">
                <span id="totalCycles" class="badge bg-secondary text-white rounded-3 py-3 w-100 fw-black" style="font-size: 2.5rem; letter-spacing: -1px;">--</span>
            </div>
        </div>
    </div>
    <div class="col-3">
        <div class="card shadow-lg rounded-4 p-4 text-center d-flex flex-column justify-content-between h-100" style="height: 220px;">
            <div class="fw-bold fs-4 text-black text-uppercase tracking-wider">ESTADO DEL OVEN</div>
            <div class="d-flex align-items-center justify-content-center flex-grow-1">
                <!-- Iniciará en color secundario hasta recibir datos -->
                <span id="ovenStatus" class="badge bg-secondary text-white rounded-3 py-3 w-100 fw-black text-uppercase" style="font-size: 2.3rem; letter-spacing: -1px;">STANDBY</span>
            </div>
        </div>
    </div>
</div>



@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        // 1. Capturar el número de horno de forma segura
        const ovenId = parseInt('@ViewBag.OvenNumber') || 0;

        // Instancias globales para controlar las gráficas
        let pressureChart;
        let temperatureChart;

        // Opciones optimizadas de alto rendimiento para las gráficas
        const chartOptionsOptimized = {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            parsing: true,
            spanGaps: true,
            elements: {
                line: {
                    borderWidth: 2,
                    tension: 0.1
                }
            },
            scales: {
                x: { ticks: { maxTicksLimit: 15 } }
            }
        };

        function loadLatestData() {
            // 1. Petición para Presión, Temperatura y Estado
            fetch(`/Oven/GettLatest?oven=${ovenId}`)
            .then(r => r.json())
            .then(d => {
                if (d) {
                    const presionTexto = d.Pess !== undefined ? d.Pess : d.pess;
                    const temperatura = d.Temp !== undefined ? d.Temp : d.temp;

                    document.getElementById("lastPressure").textContent = (presionTexto || "0") + " KPA";
                    document.getElementById("lastTemperature").textContent = (temperatura || "0") + " °C";

                    // --- EVALUACIÓN DE ESTADO REAL A 500 KPA ---
                    const presionNum = parseFloat(presionTexto) || 0;
                    const badgeEstado = document.getElementById("ovenStatus");

                    if (presionNum >= 500) {
                        // Al marcar más de 500 KPA se confirma que está en proceso
                        badgeEstado.textContent = "CICLO ACTIVO";
                        badgeEstado.className = "badge bg-success text-white rounded-3 py-3 w-100 fw-black text-uppercase";
                    } else {
                        badgeEstado.textContent = "DETENIDO";
                        badgeEstado.className = "badge bg-dark text-white rounded-3 py-3 w-100 fw-black text-uppercase";
                    }
                }
            })
            .catch(err => console.error("Error en GettLatest:", err));

            // 2. Petición para el conteo de ciclos (Independiente)
            fetch(`/Oven/GetTurnCycles?oven=${ovenId}`)
            .then(r => r.json())
            .then(ciclosOriginales => {
                const total = parseFloat(ciclosOriginales) || 0;

                // Dependiendo de tu proceso, mantén la división o usa el total directo
                const ciclosDivididos = total / 2;

                document.getElementById("totalCycles").textContent = Number(ciclosDivididos.toFixed(1));
            })
            .catch(err => console.error("Error en GetTurnCycles:", err));
        }


        // 3. Inicializar e inyectar datos en las gráficas por primera vez
        function loadCharts() {
            fetch(`/Oven/GetByTurno?oven=${ovenId}`)
            .then(r => r.json())
            .then(data => {
                if (!data || data.length === 0) return;

                const labels = data.map(x => x.hors);
                const press = data.map(x => parseFloat(x.pess) || 0);
                const temp = data.map(x => parseFloat(x.temp) || 0);

                // Gráfica de Presión
                const ctxPress = document.getElementById("PressureChart").getContext("2d");
                pressureChart = new Chart(ctxPress, {
                    type: "line",
                    data: {
                        labels: labels,
                        datasets: [{
                            label: "Pressure",
                            data: press,
                            borderColor: "orange",
                            backgroundColor: "rgba(255, 165, 0, 0.05)",
                            pointRadius: 0,
                            pointHoverRadius: 3,
                            fill: true
                        }]
                    },
                    options: chartOptionsOptimized
                });

                // Gráfica de Temperatura
                const ctxTemp = document.getElementById("TemperatureChart").getContext("2d");
                temperatureChart = new Chart(ctxTemp, {
                    type: "line",
                    data: {
                        labels: labels,
                        datasets: [{
                            label: "Temperature",
                            data: temp,
                            borderColor: "red",
                            backgroundColor: "rgba(220, 53, 69, 0.05)",
                            pointRadius: 0,
                            pointHoverRadius: 3,
                            fill: true
                        }]
                    },
                    options: chartOptionsOptimized
                });
            })
            .catch(err => console.error("Error cargando gráficas:", err));
        }

        // 4. Actualizar las curvas de las gráficas sin redibujar el canvas entero
        function updateCharts() {
            fetch(`/Oven/GetByTurno?oven=${ovenId}`)
            .then(r => r.json())
            .then(data => {
                if (!data || data.length === 0) return;

                const labels = data.map(x => x.hors);

                if (pressureChart) {
                    pressureChart.data.labels = labels;
                    pressureChart.data.datasets[0].data = data.map(x => parseFloat(x.pess) || 0);
                    pressureChart.update();
                }

                if (temperatureChart) {
                    temperatureChart.data.labels = labels;
                    temperatureChart.data.datasets[0].data = data.map(x => parseFloat(x.temp) || 0);
                    temperatureChart.update();
                }
            })
            .catch(err => console.error("Error al actualizar gráficas:", err));
        }

        // 5. Orquestación y Loop de ejecución continua cada minuto (60000ms)
        document.addEventListener("DOMContentLoaded", () => {
            // Carga inicial inmediata
            loadLatestData();
            loadCharts();

            // Loop repetitivo cada 1 minuto
            setInterval(() => {
                loadLatestData();
                updateCharts();
            }, 10000);
        });
    </script>


    <script>
        function actualizarFechaHoraYTurno() {
            const ahora = new Date();

            const meses = [
                "enero", "febrero", "marzo", "abril", "mayo", "junio",
                "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"
            ];

            const dia = ahora.getDate().toString().padStart(2, "0");
            const mes = meses[ahora.getMonth()];
            const año = ahora.getFullYear();

            let horas = ahora.getHours();
            const minutos = ahora.getMinutes().toString().padStart(2, "0");

            const ampm = horas >= 12 ? "p.m." : "a.m.";
            horas = horas % 12;
            horas = horas ? horas : 12;

            const horaFormateada = `${horas.toString().padStart(2, "0")}:${minutos} ${ampm}`;

            // Fecha + hora con ícono
            document.getElementById("fechaHoraLinea").innerHTML =
                `<i class="bi bi-calendar-date me-1"></i>${dia} de ${mes} de ${año}, ${horaFormateada}`;

            const hora24 = ahora.getHours();
            const minuto = ahora.getMinutes();

            let turno = "";

            if ((hora24 > 7 || (hora24 === 7 && minuto >= 0)) &&
                (hora24 < 15 || (hora24 === 15 && minuto <= 30))) {
                turno = "Turno 1";
            }
            else if ((hora24 > 15 || (hora24 === 15 && minuto >= 30)) &&
                     hora24 < 24) {
                turno = "Turno 2";
            }
            else {
                turno = "Turno 3";
            }

            // Turno con ícono
            document.getElementById("turnoActual").innerHTML =
                `<i class="bi bi-clock-history me-1"></i>${turno}`;
        }

        setInterval(actualizarFechaHoraYTurno, 1000);
        actualizarFechaHoraYTurno();
    </script>
}