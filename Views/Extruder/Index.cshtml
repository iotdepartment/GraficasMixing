@model List<GraficasMixing.Models.SetPointExtruder>

@{
    var extruders = ViewBag.Extruders as List<string>;

    ViewData["Title"] = "Extruder Efficiency";
}

<style>
    .sticky-filters {
        position: sticky;
        top: 0; /* o la altura de tu navbar si tienes una */
        z-index: 999; /* para que quede encima de las gráficas */
        background: white; /* evita transparencia al hacer scroll */
    }

    .sticky-filters {
        top: 5px;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <h2 class="text-start">Mesus Charts (Extruder Area) <i class="bi bi-clipboard-data"></i></h2>
    <hr class="border border-dark border-0 mb-4 opacity-100">

<!-- Nuevo botón para ir a la vista de Chart -->
<div class="row mb-3 mt-2">
    <div class="col-12 d-flex justify-content-end align-items-center gap-2">
        <!-- Texto a la izquierda -->
        <span class="fw-bold me-2">Extruder Resume:</span>

        <!-- Select de extruder -->
        <select id="extruderSelect" class="form-select w-auto" onchange="redirigirExtruder()">
            <option value="">-- Select Extruder --</option>
            <option value="1">Extruder 1</option>
            <option value="2">Extruder 2</option>
            <option value="3">Extruder 3</option>
            <option value="4">Extruder 4</option>
            <option value="5">Extruder 5</option>
            <option value="6">Extruder 6</option>
        </select>
    </div>
</div>

<!-- CONTROLES PARA LAS CHARTS -->
<div class="card shadow-sm border border-1 bg-white rounded-4 p-3 sticky-filters">
    <div class="row align-items-end">

        <!-- Extruder -->
        <div class="col-2">
            <label for="ExtruderSelect" class="fw-bold">Extruder:</label><br>
            <select id="ExtruderSelect" class="form-select">
                @foreach (var extruder in extruders)
                {
                    <option value="@extruder">@extruder</option>
                }
            </select>
        </div>

        <!-- Shift -->
        <div class="col-2">
            <label for="shiftSelect" class="fw-bold">Shift:</label><br>
            <select id="shiftSelect" class="form-select">
                <option value="Turno1" selected>Shift 1 (7:00 - 15:00)</option>
                <option value="Turno2">Shift 2 (15:00 - 24:00)</option>
                <option value="Turno3">Shift 3 (00:00 - 7:00)</option>
                <option value="All">All</option>
            </select>
        </div>

        <!-- Date -->
        <div class="col-1">
            <label for="startDate" class="fw-bold">Date:</label><br>
            <input type="date" id="startDate" class="form-control" max="@DateTime.Now.ToString("yyyy-MM-dd")">
        </div>

        <!-- Apply Filter -->
        <div class="col-1">
            <div class="d-grid gap-2">
                <button type="button" id="applyFilter" class="btn btn-primary rounded-pill">
                    <i class="bi bi-search"></i> Apply
                    <span id="spinner" class="spinner-border spinner-border-sm" style="display:none;"></span>
                </button>
            </div>
        </div>

        <!-- SetPoints -->
        <div class="col-1">
            <div class="d-grid gap-2">
                <button type="button" id="openSetPointModal" class="btn btn-success rounded-pill">
                    <i class="bi bi-gear"></i> SetPoints
                </button>
            </div>
        </div>

        <!-- General Chart -->
        <div class="col-2">
            <div class="d-grid gap-2">
                <button id="ButtonGeneralChart"
                        class="btn btn-info rounded-pill"
                        onclick="location.href='@Url.Action("GeneralChart", "Extruder")'">
                    <i class="bi bi-graph-up"></i> Open General Chart
                </button>
            </div>
        </div>

        <!-- Export Charts -->
        <div class="col-2">
            <div class="d-grid gap-2 ">
                <button id="btnExport" class="rounded-pill btn btn-success">
                    Export Charts
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Canvas oculto para renderizar las gráficas -->
<canvas id="hiddenCanvas" style="display:none;"></canvas>

<!-- MODAL PARA EDITAR LOS SETPOINTS -->
@await Html.PartialAsync("Partials/_ExtruderModal", Model)

<!-- EFICIENCIA DEL DÍA | PORCENTAJE DE PRODUCCION POR TURNO | PORCENTAJE DE TIEMPO MUERTO POR TURNO -->
<div class="row g-3 mt-1 mb-4">

    <!-- Gráfica 1 -->
    <div class="col-4">
        <div class="card shadow-sm border border-1 rounded-4 p-3 d-flex justify-content-center align-items-center" style="height: 480px;">
            <canvas id="EficienciaRealPieChart" width="200" height="200"></canvas>
            <canvas id="Extruder2EficienciaRealPieChart" style="display:none"></canvas>

        </div>
    </div>

    <!-- Gráfica 2 -->
    <div class="col-4">
        <div class="card shadow-sm border border-1 rounded-4 p-3 d-flex justify-content-center align-items-center" style="height: 480px;">
            <canvas id="EfficiencyBarChart"></canvas>
            <canvas id="Extruder2EfficiencyChart" style="display:none"></canvas>
        </div>
    </div>

    <!-- Gráfica 3 -->
    <div class="col-4">
        <div class="card shadow-sm border border-1 rounded-4 p-3 d-flex justify-content-center align-items-center" style="height: 480px;">
            <canvas id="DowntimeBarChart"></canvas>
            <canvas id="Extruder2DowntimeBarChart" style="display:none"></canvas>
        </div>
    </div>
</div>

<!-- PRODUCCION POR FAMILIA (TABLA) -->
<div class="row">
     <div class="col-3">
        <div class="card mx-auto text-center shadow-sm border-0 rounded-4 p-4 mt-2">
            <h5 class="m-0 fw-bold">PRODUCCIÓN POR FAMILIA</h5>
        </div>
     </div>
</div>
<div class="row mb-4">
    <div class="col-12">
        <div class="card shadow-sm border border-0 rounded-4  p-4 mt-2">

            <div class="table-responsive">
                <table id="produccionTable" class="table mb-0 table-striped table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Familia</th>
                            <th>Metros Producidos</th>
                            <th>Velocidad Promedio (m/min)</th>
                            <th>SetPoint Velocidad (m/min)</th>
                            <th>% Efectividad</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- EFICIENCIA DIARIA DE LOS ULTIMOS 7 DÍAS -->
<div class="row align-items-end mb-4">
    <div class="col-12 mb-2">
        <div class="card shadow-sm border border-1 rounded-4 p-3 d-flex justify-content-center align-items-center" style="height: 360px;">
            <canvas id="DailyEfficiencyChart" width="50" height="10"></canvas>
        </div>
    </div>
</div>
        
<!-- TIEMPO DE PRODUCCION POR FAMILIA | METROS EXTRUIDOS POR FAMILIA -->
<div class="row g-3 mb-4">
    <div class="col-6">
        <div class="card shadow-sm border border-1 rounded-4 p-3">
            <canvas id="FamilyStackedChart" style="width:100%; height:360px;"></canvas>
        </div>
    </div>

    <div class="col-6">
        <div class="card shadow-sm border border-1 rounded-4 p-3">
            <canvas id="FamilyMetersChart" style="width:100%; height:360px;"></canvas>
        </div>
    </div>
</div>

<!-- CHART VELOCIODAD DURANTE EL DÍA -->
<div class="row align-items-end mb-4">
    <div class="row">
        <button type="button" class="btn btn-outline-secondary btn-sm mb-2 w-100" id="btnToggleMode" onclick="toggleGraphMode()">
            🔄 Ver desglose de Paros (PP)
        </button>
    </div>
    <div class="col-12 mb-2">
        <div class="card shadow-sm border border-1 rounded-4 p-3 d-flex justify-content-center align-items-center" style="height: 360px;">
            <canvas id="SpeedLineChart" style="width:100%; height:100%;"></canvas>
        </div>
    </div>
</div>

<!-- Mensaje de error inline -->
<div id="errorMessage" class="text-danger fw-bold mt-3"></div>

@section Scripts {
    <!-- Importar Chart.js y el plugin de datalabels -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels"></script>

    <script>
        function redirigirExtruder() {
            const id = document.getElementById("extruderSelect").value;
            if (id) {
                window.location.href = '/Extruder/Chart?id=' + encodeURIComponent(id);
            }
        }
    </script>

    <script>
        // Abrir modal al hacer clic en el botón
        document.getElementById("openSetPointModal").addEventListener("click", function () {
            var modal = new bootstrap.Modal(document.getElementById("extruderModal"));
            modal.show();
        });
    </script>

    <script>
        // let totmChart;
        let efficiencyChart;
        let downtimeChart = null;
        let dailyEfficiencyChart;
        let familyStackedChart;
        let familyMetersChart;
        // let speedChart;
        let eficienciaRealPieChart;
        let speedChart = null;
        let lastSpeedResult = null;
        let currentMode = "PROD";
        
        //EFICIENCIA DIARIA %
        async function loadEficienciaRealPieChart() {

            const extruder = document.getElementById("ExtruderSelect").value;
            const shift = document.getElementById("shiftSelect").value;
            const date = document.getElementById("startDate").value;

            const spinner = document.getElementById("spinner");
            const errorMessage = document.getElementById("errorMessage");

            spinner.style.display = "inline-block";
            errorMessage.innerText = "";

            try {
                const response = await fetch(`/Extruder/GetEficienciaRealData?extruder=${extruder}&shift=${shift}&date=${date}`);
                const data = await response.json();

                const eficienciaReal = Math.min(data.eficienciaReal, 100);
                const perdida = Math.max(100 - eficienciaReal, 0);        

                const ctx = document.getElementById("EficienciaRealPieChart").getContext("2d");
                const chartTitle = `Eficiencia – ${extruder} – ${shift} (${date})`;

                if (!eficienciaRealPieChart) {

                    eficienciaRealPieChart = new Chart(ctx, {
                        type: 'pie',
                        data: {
                            labels: ["Eficiencia", "Pérdida"],
                            datasets: [{
                                data: [eficienciaReal, perdida],
                                backgroundColor: ["#4CAF50", "#EF5350"],
                                borderColor: "#fff",
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            animation: {
                                duration: 1200,
                                easing: "easeOutQuart"
                            },
                            plugins: {
                                legend: { position: "bottom" },
                                title: {
                                    display: true,
                                    text: chartTitle,
                                    font: { size: 18, weight: "bold" },
                                    color: "#333"
                                },
                                datalabels: {
                                    color: "#fff",
                                    font: { weight: "bold", size: 16 },
                                    formatter: (value) => `${value.toFixed(1)}%`
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function (context) {
                                            return `${context.label}: ${context.raw.toFixed(2)}%`;
                                        }
                                    }
                                }
                            }
                        },
                        plugins: [ChartDataLabels]
                    });

                } else {

                    eficienciaRealPieChart.data.datasets[0].data = [eficienciaReal, perdida];
                    eficienciaRealPieChart.options.plugins.title.text = chartTitle;

                    eficienciaRealPieChart.update();
                }

            } catch (error) {
                errorMessage.innerText = "Error cargando datos de eficiencia real.";
            } finally {
                spinner.style.display = "none";
            }
        }

        //PORCENTAJE DE PRODUCCION POR TURNO
        async function loadEfficiencyChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const date = document.getElementById("startDate").value;

            const response = await fetch(`/Extruder/GetEfficiencyByShift?extruder=${extruder}&date=${date}`);
            const result = await response.json();

            // 🔹 Usa siempre label + value
            const labels = result.map(r => r.label ?? r.shift);
            const data = result.map(r => r.value ?? r.efficiency);

            const ctx = document.getElementById("EfficiencyBarChart").getContext("2d");

            if (!efficiencyChart) {
                efficiencyChart = new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels: labels,
                        datasets: [{
                            label: "Producción (%)",
                            data: data,
                            backgroundColor: ["rgba(49, 92, 213)", "rgba(49, 92, 213)", "rgba(49, 92, 213)"]
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: {
                            duration: 1200,
                            easing: "easeOutQuart"
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 100,
                                ticks: {
                                    callback: function(value) {
                                        return value + "%";
                                    }
                                }
                            }
                        },
                        plugins: {
                            title: {
                                display: true,
                                text: "Porcentaje de producción por turno (%)",
                                font: { size: 18, weight: "bold" },
                                color: "#333",
                                padding: { top: 20, bottom: 10 }
                            },
                            datalabels: {
                                anchor: "center",
                                align: "center",
                                formatter: function(value) {
                                    return (value !== undefined && value !== null && !isNaN(value))
                                        ? value.toFixed(1) + "%"
                                        : "";
                                },
                                font: { weight: "bold" },
                                color: "#fff"
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const raw = context.raw;
                                        return (raw !== undefined && raw !== null && !isNaN(raw))
                                            ? `${context.label}: ${raw.toFixed(2)}%`
                                            : `${context.label}: -`;
                                    }
                                }
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            } else {
                efficiencyChart.data.labels = labels;
                efficiencyChart.data.datasets[0].data = data;
                efficiencyChart.update();
            }
        }
        
        // PALETA DE COLORES PARA LOS PAROS PROGRAMADOS
        const colorPalette = [
            'rgba(255, 99, 132, 1.0)', 'rgba(54, 162, 235, 1.0)', 'rgba(255, 206, 86, 1.0)',
            'rgba(75, 192, 192, 1.0)', 'rgba(153, 102, 255, 1.0)', 'rgba(255, 159, 64, 1.0)'
        ];

        //PAROS PROGRAMADOS POR TURNO
        async function loadDowntimeChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const date = document.getElementById("startDate").value;

            if (!date) return;

            try {
                const response = await fetch(`/Extruder/GetDowntimeByShift?extruder=${extruder}&date=${date}`);
                const result = await response.json();

                // Mapear los datos recibidos del servidor a datasets de Chart.js
                const datasets = result.desglose.map((item, index) => ({
                    label: item.codigoPP,
                    data: item.datosPorTurno, // Array de 3 posiciones [T1, T2, T3]
                    backgroundColor: colorPalette[index % colorPalette.length],
                    stack: 'Stack 0' // Indica que pertenecen a la misma pila
                }));

                const ctx = document.getElementById("DowntimeBarChart").getContext("2d");

                if (!downtimeChart) {
                    downtimeChart = new Chart(ctx, {
                        type: "bar",
                        data: {
                            labels: result.turnos, // ["Turno 1", "Turno 2", "Turno 3"]
                            datasets: datasets
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                x: { stacked: true }, // Habilitar apilado X
                                y: {
                                    stacked: true,    // Habilitar apilado Y
                                    beginAtZero: true,
                                    ticks: {
                                        callback: value => value + " min"
                                    }
                                }
                            },
                            plugins: {
                                title: {
                                    display: true,
                                    text: "Desglose de Tiempo Muerto por Código PP (Minutos)",
                                    font: { size: 18, weight: "bold" }
                                },
                                datalabels: {
                                    anchor: "center",
                                    align: "center",
                                    formatter: value => value > 0 ? value + " min" : "", // Ocultar etiquetas si es 0
                                    font: { weight: "bold", size: 11 },
                                    color: "#fff"
                                },
                                tooltip: {
                                    callbacks: {
                                        label: context => `${context.dataset.label}: ${context.raw} min`
                                    }
                                }
                            }
                        },
                        plugins: [ChartDataLabels]
                    });
                } else {
                    // Actualizar datos de forma dinámica
                    downtimeChart.data.labels = result.turnos;
                    downtimeChart.data.datasets = datasets;
                    downtimeChart.update();
                }
            } catch (error) {
                console.error("Error al renderizar los minutos de PP:", error);
            }
        }

        //TABLA PRODCCION POR FAMILIA
        function cargarProduccionFamilias() {
            const fecha = document.getElementById("startDate").value;
            const turno = document.getElementById("shiftSelect").value;
            const extruder = document.getElementById("ExtruderSelect").value;

            document.getElementById("spinner").style.display = "inline-block";

            fetch(`/Extruder/GetProduccionFamilias?extruder=${extruder}&shift=${turno}&date=${fecha}`)
                .then(response => response.json())
                .then(data => {
                    const tbody = document.querySelector("#produccionTable tbody");
                    tbody.innerHTML = "";

                    data.forEach(item => {
                        const row = `<tr>
                            <td>${item.familia}</td>
                            <td>${item.metrosProducidos}</td>
                            <td>${item.velocidadPromedio.toFixed(2)}</td>
                            <td>${item.setPointVelocidad}</td>
                            <td>${item.porcentajeEfectividad.toFixed(2)} %</td>
                        </tr>`;
                        tbody.innerHTML += row;
                    });

                    document.getElementById("spinner").style.display = "none";
                });
        }

        // EFICIENCIA DIARIA DE LOS ÚLTIMOS 7 DÍAS
        async function loadDailyEfficiencyChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const shift = document.getElementById("shiftSelect").value;
            const date = document.getElementById("startDate").value;

            try {
                const response = await fetch(`/Extruder/GetDailyEficienciaRealLast7Days?extruder=${extruder}&shift=${shift}&date=${date}`);
                const result = await response.json();

                // 🔹 Usa siempre label + value
                const labels = result.map(r => r.label ?? r.date);
                const data = result.map(r => Number(r.value ?? r.eficienciaReal));

                const ctx = document.getElementById("DailyEfficiencyChart").getContext("2d");

                if (!window.dailyEfficiencyChart) {
                    window.dailyEfficiencyChart = new Chart(ctx, {
                        type: "bar",
                        data: {
                            labels: labels,
                            datasets: [{
                                label: "Eficiencia (%)",
                                data: data,
                                backgroundColor: "rgba(76, 175, 80, 0.8)", // verde
                                borderWidth: 2
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    max: 120, // puede superar 100
                                    ticks: {
                                        callback: value => value + "%"
                                    }
                                }
                            },
                            plugins: {
                                title: {
                                    display: true,
                                    text: "Eficiencia de los últimos 7 días",
                                    font: { size: 18, weight: "bold" },
                                    color: "#333"
                                },
                                datalabels: {
                                    anchor: "center",
                                    align: "center",
                                    formatter: function(value) {
                                        return (value !== undefined && value !== null && !isNaN(value))
                                            ? value.toFixed(1) + "%"
                                            : "";
                                    },
                                    font: { weight: "bold" },
                                    color: "#fff"
                                },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            const raw = context.raw;
                                            return (raw !== undefined && raw !== null && !isNaN(raw))
                                                ? `${context.label}: ${raw.toFixed(2)}%`
                                                : `${context.label}: -`;
                                        }
                                    }
                                }
                            }
                        },
                        plugins: [ChartDataLabels]
                    });
                } else {
                    window.dailyEfficiencyChart.data.labels = labels;
                    window.dailyEfficiencyChart.data.datasets[0].data = data;
                    window.dailyEfficiencyChart.update();
                }
            } catch (error) {
                console.error("Error cargando datos de eficiencia real:", error);
            }
        }

        // TIEMPO DE PRODUCCIÓN POR FAMILIA
        async function loadFamilyStackedChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const date = document.getElementById("startDate").value;
            const shift = document.getElementById("shiftSelect").value;

            const response = await fetch(`/Extruder/GetFamilyRuntime?extruder=${extruder}&date=${date}&shift=${shift}`);
            const result = await response.json();

            // 🔹 Usa siempre label + value
            const labels = ["Producción"]; // una sola barra
            const datasets = result.map(r => ({
                label: r.label ?? r.family,
                data: [Number(r.value ?? r.minutes)],
                backgroundColor: getRandomColor()
            }));

            const ctx = document.getElementById("FamilyStackedChart").getContext("2d");

            if (!familyStackedChart) {
                familyStackedChart = new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels: labels,
                        datasets: datasets
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { stacked: true },
                            y: { stacked: true }
                        },
                        plugins: {
                            title: {
                                display: true,
                                text: "Tiempo de producción por familia (min)",
                                font: { size: 18, weight: "bold" },
                                padding: { top: 20, bottom: 10 }
                            },
                            datalabels: {
                                anchor: "center",
                                align: "center",
                                formatter: function(value) {
                                    return (value !== undefined && value !== null && !isNaN(value))
                                        ? value.toFixed(1) + " min"
                                        : "";
                                },
                                font: { weight: "bold" },
                                color: "#fff"
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const raw = context.raw;
                                        return (raw !== undefined && raw !== null && !isNaN(raw))
                                            ? `${context.dataset.label}: ${raw.toFixed(1)} min`
                                            : `${context.dataset.label}: -`;
                                    }
                                }
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            } else {
                familyStackedChart.data.labels = labels;
                familyStackedChart.data.datasets = datasets;
                familyStackedChart.update();
            }
        }

        function getRandomColor() {
            return `hsl(${Math.floor(Math.random() * 360)}, 70%, 55%)`;
        }

        // METROS EXTRUIDOS POR FAMILIA
        async function loadFamilyMetersChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const date = document.getElementById("startDate").value;
            const shift = document.getElementById("shiftSelect").value;

            const response = await fetch(`/Extruder/GetFamilyMeters?extruder=${extruder}&date=${date}&shift=${shift}`);
            const result = await response.json();

            // 🔹 Usa siempre label + value
            const labels = ["Producción"]; // una sola barra
            const datasets = result.map(r => ({
                label: r.label ?? r.family,
                data: [Number(r.value ?? r.meters)],
                backgroundColor: getRandomColor()
            }));

            const ctx = document.getElementById("FamilyMetersChart").getContext("2d");

            if (!familyMetersChart) {
                familyMetersChart = new Chart(ctx, {
                    type: "bar",
                    data: {
                        labels: labels,
                        datasets: datasets
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { stacked: true },
                            y: { stacked: true }
                        },
                        plugins: {
                            title: {
                                display: true,
                                text: "Metros extruidos por familia (m)",
                                font: { size: 18, weight: "bold" },
                                padding: { top: 20, bottom: 10 }
                            },
                            datalabels: {
                                anchor: "center",
                                align: "center",
                                formatter: function(value) {
                                    return (value !== undefined && value !== null && !isNaN(value))
                                        ? value.toFixed(1) + " m"
                                        : "";
                                },
                                font: { weight: "bold" },
                                color: "#fff"
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const raw = context.raw;
                                        return (raw !== undefined && raw !== null && !isNaN(raw))
                                            ? `${context.dataset.label}: ${raw.toFixed(1)} m`
                                            : `${context.dataset.label}: -`;
                                    }
                                }
                            }
                        }
                    },
                    plugins: [ChartDataLabels]
                });
            } else {
                familyMetersChart.data.labels = labels;
                familyMetersChart.data.datasets = datasets;
                familyMetersChart.update();
            }
        }

        async function loadSpeedChart() {
            const extruder = document.getElementById("ExtruderSelect").value;
            const date = document.getElementById("startDate").value;
            const shift = document.getElementById("shiftSelect").value;

            if (!date) return;

            try {
                const response = await fetch(`/Extruder/GetSpeedData?extruder=${extruder}&date=${date}&shift=${shift}`);
                lastSpeedResult = await response.json(); // Guardamos el resultado globalmente

                // Cada vez que se cargan datos nuevos, reiniciamos al modo producción por defecto
                currentMode = "PROD";
                document.getElementById("btnToggleMode").innerHTML = "🔄 Ver desglose de Paros (PP)";

                renderSpeedChart();
            } catch (error) {
                console.error("Error al cargar datos de velocidad:", error);
            }
        }

        const colors = [
            "rgba(54, 162, 235, 1)",   // azul
            "rgba(255, 206, 86, 1)",   // amarillo
            "rgba(153, 102, 255, 1)",  // morado
            "rgba(255, 159, 64, 1)",   // naranja
            "rgba(75, 192, 192, 1)"    // verde agua
        ];


        function renderSpeedChart() {
            if (!lastSpeedResult) return;

            // 1. Obtener todos los timestamps únicos para el eje X
            const allLabels = [...new Set(lastSpeedResult.map(r => r.label))];

            // 2. Agrupación DINÁMICA según el modo activo
            const groupedData = {};

            lastSpeedResult.forEach(r => {
                let key = "";

                if (currentMode === "PROD") {
                    // MODO PRODUCCIÓN: Si es paro, todo va a "Tiempo Muerto". Si produce, se separa por su familia.
                    key = r.isPP ? "Tiempo Muerto" : (r.family ?? "FAMILIA NO IDENTIFICADA");
                } else {
                    // MODO PAROS (PP): Si produce, todo va a "Producción". Si es paro, se separa por su código PP.
                    key = r.isPP ? (r.family ?? "TIEMPO MUERTO NO IDENTIFICADO") : "Producción";
                }

                if (!groupedData[key]) groupedData[key] = [];
                groupedData[key].push(r);
            });

            // 3. Creación de Datasets basados en la nueva agrupación temporal
            let colorIndex = 0;
            const datasets = Object.keys(groupedData).map(keyName => {
                const items = groupedData[keyName];

                // Evaluamos si este bloque agrupado corresponde a un paro o no
                const isBlockPP = items.some(r => r.isPP === true);

                let borderColor = "";
                let isUnified = false;

                // Determinación estricta de colores y estilos según el requerimiento
                if (currentMode === "PROD") {
                    if (keyName === "Tiempo Muerto") {
                        borderColor = "rgba(235, 54, 54, 1)"; // Rojo único para el bloque consolidado
                        isUnified = true;
                    } else {
                        borderColor = colors[colorIndex % colors.length]; // Familias desglosadas por color
                        colorIndex++;
                    }
                } else {
                    if (keyName === "Producción") {
                        borderColor = "rgba(40, 167, 69, 1)"; // Verde único para la producción consolidada
                        isUnified = true;
                    } else {
                        borderColor = colors[colorIndex % colors.length]; // Reutiliza los mismos colores para los PP desglosados
                        colorIndex++;
                    }
                }

                const backgroundColor = borderColor.replace("1)", "0.2)");

                return {
                    label: keyName,
                    // Mapeo lineal: Buscamos el punto correspondiente al timestamp del eje X
                    data: allLabels.map(ts => {
                        const item = items.find(x => x.label === ts);
                        return item ? item.value : null;
                    }),
                    borderColor: borderColor,
                    backgroundColor: backgroundColor,
                    borderWidth: isBlockPP ? 3 : 2,
                    tension: 0.3,
                    fill: false,
                    // Línea discontinua para cualquier representación de paros (bloque unificado o desglosado)
                    borderDash: isBlockPP ? [6, 6] : [],
                    clip: false,
                    // Guardamos metadatos para el ordenamiento
                    isPP: isBlockPP,
                    isUnified: isUnified
                };
            });

            // 4. ORDENAR: En modo PROD las familias primero, en modo PP los paros primero. Los bloques consolidados al final.
            datasets.sort((a, b) => {
                if (currentMode === "PROD") {
                    if (a.label === "Tiempo Muerto") return 1;
                    if (b.label === "Tiempo Muerto") return -1;
                } else {
                    if (a.label === "Producción") return 1;
                    if (b.label === "Producción") return -1;
                }
                return a.label.localeCompare(b.label);
            });

            // 5. Dibujar o Actualizar en Chart.js
            const ctx = document.getElementById("SpeedLineChart").getContext("2d");

            if (!speedChart) {
                speedChart = new Chart(ctx, {
                    type: "line",
                    data: { labels: allLabels, datasets: datasets },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true },
                            x: {
                                offset: true,
                                ticks: {
                                    callback: function(value) {
                                        const label = this.getLabelForValue(value);
                                        return new Date(label).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                                    },
                                    maxRotation: 45,
                                    minRotation: 30
                                }
                            }
                        },
                        plugins: {
                            title: {
                                display: true,
                                text: "Monitoreo de Velocidad de Extrusor (m/min)",
                                font: { size: 18, weight: "bold" },
                                color: "#333",
                                padding: { top: 15, bottom: 5 }
                            },
                            legend: {
                                position: "bottom",
                                labels: { font: { size: 12, weight: "bold" }, color: "#333", padding: 15 }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const raw = context.raw;
                                        return (raw !== undefined && raw !== null && !isNaN(raw))
                                            ? `${context.dataset.label}: ${raw.toFixed(1)} m/min`
                                            : `${context.dataset.label}: -`;
                                    }
                                }
                            }
                        }
                    }
                });
            } else {
                speedChart.data.labels = allLabels;
                speedChart.data.datasets = datasets;
                speedChart.update();
            }
        }

        // 3. Función del botón para intercambiar los modos
        function toggleGraphMode() {
            const btn = document.getElementById("btnToggleMode");

            if (currentMode === "PROD") {
                currentMode = "PP";
                btn.innerHTML = "🔄 Ver desglose de Producción (Familias)";
            } else {
                currentMode = "PROD";
                btn.innerHTML = "🔄 Ver desglose de Paros (PP)";
            }

            // Redibujamos aplicando las reglas del nuevo modo
            renderSpeedChart();
        }

        // EXPORTAR GRAFICAS
        document.getElementById("btnExport").addEventListener("click", async () => {
            const btn = document.getElementById("btnExport");
            btn.disabled = true; // 🔹 Deshabilitar mientras exporta
            btn.textContent = "Wait..."; // opcional, cambia el texto

            const extruder = document.getElementById("ExtruderSelect").value;
            const shift = document.getElementById("shiftSelect").value;
            const date = document.getElementById("startDate").value;

            try {
                const response = await fetch("/Extruder/GenerateExcelAllExtruders", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ extruder, shift, date })
                });

                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement("a");
                    a.href = url;
                    a.download = "Reporte.xlsx";
                    document.body.appendChild(a);
                    a.click();
                    a.remove();
                } else {
                    alert("Error al generar el reporte");
                }
            } catch (err) {
                console.error("Error:", err);
                alert("Error al conectar con el servidor");
            } finally {
                btn.disabled = false; // 🔹 Rehabilitar al terminar
                btn.textContent = "Export Charts"; // restaurar texto
            }
        });

        // Evento del botón Apply
        document.getElementById("applyFilter").addEventListener("click", loadEfficiencyChart);
        document.getElementById("applyFilter").addEventListener("click", loadDowntimeChart);
        document.getElementById("applyFilter").addEventListener("click", loadDailyEfficiencyChart);
        document.getElementById("applyFilter").addEventListener("click", loadFamilyStackedChart);
        document.getElementById("applyFilter").addEventListener("click", loadFamilyMetersChart);
        document.getElementById("applyFilter").addEventListener("click", loadSpeedChart);
        document.getElementById("applyFilter").addEventListener("click", cargarProduccionFamilias);
        document.getElementById("applyFilter").addEventListener("click", loadEficienciaRealPieChart);

        window.onload = () => {

            function getLaborDay() {
                const now = new Date();
                const hour = now.getHours();
                const minute = now.getMinutes();

                if (hour > 23 || (hour === 23 && minute >= 46) || hour < 7) {
                    now.setDate(now.getDate() - 1);
                }

                const year  = now.getFullYear();
                const month = String(now.getMonth() + 1).padStart(2, '0');
                const day   = String(now.getDate()).padStart(2, '0');

                return `${year}-${month}-${day}`;
            }

            const laborDay = getLaborDay();
            document.getElementById("startDate").value = laborDay;
            document.getElementById("shiftSelect").value = "All";

            const extruder = document.getElementById("ExtruderSelect").value;

            // loadTotmChart(extruder, "All", laborDay);
            loadEfficiencyChart(extruder, laborDay);
            loadDowntimeChart(extruder, laborDay);
            loadDailyEfficiencyChart(extruder, laborDay);
            loadFamilyStackedChart(extruder, laborDay);
            loadFamilyMetersChart(extruder, laborDay);
            loadSpeedChart(extruder, laborDay);
            cargarProduccionFamilias(extruder, laborDay);
            loadEficienciaRealPieChart(extruder, laborDay);
        };
    </script>
}