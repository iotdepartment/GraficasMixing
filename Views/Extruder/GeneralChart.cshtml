        let speedChart1;
        let speedChart3;
        let speedChart4;
        let speedChart5;
        let speedChart6;

        async function loadSpeedChart1() {
            const response = await fetch('/Extruder/GetSpeedDataToday1');
            const data = await response.json();

            const ctx = document.getElementById('ExtruderChart1').getContext('2d');

            if (!data || data.length === 0) {
                ctx.font = "8px Arial";
                ctx.fillText("No hay datos disponibles para hoy", 50, 100);
                return;
            }

            const labels = [...new Set(data.map(item => item.timestamp))];
            const familias = [...new Set(data.map(item => item.family))];

            const colors = [
                "rgba(255, 99, 132, 1)",
                "rgba(54, 162, 235, 1)",
                "rgba(75, 192, 192, 1)",
                "rgba(255, 206, 86, 1)",
                "rgba(153, 102, 255, 1)",
                "rgba(255, 159, 64, 1)"
            ];

            const datasets = familias.map((fam, index) => {
                const speeds = labels.map(ts => {
                    const registro = data.find(d => d.timestamp === ts && d.family === fam);
                    return registro ? registro.speed : null;
                });

                return {
                    label: fam,
                    data: speeds,
                    borderColor: colors[index % colors.length],
                    backgroundColor: colors[index % colors.length].replace("1)", "0.2)"),
                    tension: 0.3,
                    borderWidth: 5,
                    pointRadius: 0,
                    pointHoverRadius: 0  
                };
            });

            if (!speedChart1) {
                speedChart1 = new Chart(ctx, {
                    type: 'line',
                    data: { labels: labels, datasets: datasets },
                    options: {
                        responsive: true,
                        plugins: {
                            legend: {
                                position: 'top',
                                labels: {
                                    font: {
                                        size: 12,
                                        weight: 'bold'
                                    },
                                    color: '#333'
                                }
                            },
                            title: {
                                display: true,
                                text: 'Extruder 1',
                                align: 'start',
                                font: { size: 20, weight: 'bold' },
                                color: '#333'
                            }
                        },
                        scales: {
                            y: {
                                min: 0,
                                title: { display: true, text: 'Velocidad (m/min)' }
                            },
                            x: {
                                title: { display: true, text: 'Hora' },
                                ticks: {
                                    callback: function(value) {
                                        const label = this.getLabelForValue(value);
                                        const dateObj = new Date(label);
                                        return dateObj.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                                    }
                                }
                            }
                        }
                    }
                });
            } else {
                speedChart1.data.labels = labels;
                speedChart1.data.datasets = datasets;
                speedChart1.update();
            }

        }

