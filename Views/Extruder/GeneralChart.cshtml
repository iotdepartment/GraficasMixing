@model List<GraficasMixing.Models.ScadaExtrudermaster>

@{
    Layout = "~/Views/Extruder/Partials/_LayoutNoNav.cshtml";
    ViewData["Title"] = "Extruder Charts";
}
<div class="row align-items-end mt-2">
    <div class="row">
        <div class="col-2 d-flex align-items-stretch">
            <div class="card shadow-sm border-0 rounded-4 d-flex justify-content-center align-items-center text-center w-100 h-75">
                <img src="~/Images/Logo.png"
                     alt="Logo empresa"
                     class="img-fluid"
                     style="max-width: 100px; height: auto;">
            </div>
        </div>
        <div class="col-10">
            <div class="card shadow-sm border border-1 rounded-4 p-2 mb-2 position-relative bg-info">

                <div class="fw-bold fs-1">Sistema de graficas de Extruder</div>
            </div>
        </div>
    </div>
</div>
<div class="row mt-1">
    <div class="col-12">
        <div class="row align-items-end mb-2">
            <div class="card shadow-sm border border-1 rounded-4 p-1 position-relative" style="height: 250px;">
                <canvas id="ExtruderChart1" style="width:100%; height:100%;"></canvas>
            </div>
        </div>
        <div class="row align-items-end mb-2">
            <div class="card shadow-sm border border-1 rounded-4 p-1 position-relative" style="height: 250px;">
                <canvas id="ExtruderChart3" style="width:100%; height:100%;"></canvas>
